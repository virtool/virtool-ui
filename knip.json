{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignoreExportsUsedInFile": true,
	"ignoreDependencies": ["conventional-changelog-conventionalcommits"],
	"workspaces": {
		"apps/web": {
			"entry": [
				"src/client.tsx",
				"src/server.ts",
				"src/start.ts",
				"src/router.tsx",
				"src/instrument.server.ts",
				"src/routes/**/*.{ts,tsx}",
				"src/server/storage/index.ts",
				"src/types/window.ts",
				"src/tests/postgresGuard.ts"
			],
			"project": ["src/**/*.{ts,tsx}"],
			"ignoreDependencies": ["tailwindcss", "@tanstack/router-cli"]
		},
		"packages/bio": {
			"entry": ["src/**/*.test.ts"]
		},
		"packages/logger": {
			"entry": ["src/**/*.test.ts"]
		}
	}
}
