{
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
            "@account/*": ["./src/account/*"],
            "@administration/*": ["./src/administration/*"],
            "@analyses/*": ["./src/analyses/*"],
            "@app/*": ["./src/app/*"],
            "@base/*": ["./src/base/*"],
            "@dev/*": ["./src/dev/*"],
            "@forms/*": ["./src/forms/*"],
            "@groups/*": ["./src/groups/*"],
            "@hmm/*": ["./src/hmm/*"],
            "@indexes/*": ["./src/indexes/*"],
            "@jobs/*": ["./src/jobs/*"],
            "@labels/*": ["./src/labels/*"],
            "@message/*": ["./src/message/*"],
            "@ml/*": ["./src/ml/*"],
            "@nav/*": ["./src/nav/*"],
            "@otus/*": ["./src/otus/*"],
            "@quality/*": ["./src/quality/*"],
            "@references/*": ["./src/references/*"],
            "@samples/*": ["./src/samples/*"],
            "@sequences/*": ["./src/sequences/*"],
            "@subtraction/*": ["./src/subtraction/*"],
            "@tests/*": ["./src/tests/*"],
            "@uploads/*": ["./src/uploads/*"],
            "@users/*": ["./src/users/*"],
            "@wall/*": ["./src/wall/*"]
        },
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "lib": ["DOM", "ESNext", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "outDir": "./build/",
        "rootDir": "./src",
        "skipLibCheck": true,
        "strict": false,
        "target": "ESNext",
        "typeRoots": ["node_modules/@types", "./src/types"]
    },
    "include": ["src/**/*"]
}
